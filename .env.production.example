# Environment Variables untuk GCP Cloud Run Production
# Copy file ini dan sesuaikan dengan konfigurasi GCP Anda

# ============================================================================
# GCP CLOUD SQL CONFIGURATION
# ============================================================================

# Cloud SQL Connection Name (format: PROJECT_ID:REGION:INSTANCE_NAME)
# Contoh: my-project:asia-southeast2:shopfloor-db
CLOUD_SQL_CONNECTION_NAME=your-project:your-region:your-instance

# Database credentials
DB_USER=postgres
DB_PASS=your-secure-password-here
DB_NAME=shopfloor_db

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================

# Environment mode (production/development)
FLASK_ENV=production

# Secret key untuk session (GENERATE STRONG KEY!)
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-generated-secret-key-here

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed origins untuk CORS (gunakan domain spesifik di production)
# Contoh: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# ============================================================================
# CLOUD RUN CONFIGURATION
# ============================================================================

# Port untuk Cloud Run (default 8080, jangan diubah)
PORT=8080

# ============================================================================
# CATATAN DEPLOYMENT
# ============================================================================
# 
# Environment variables ini akan di-set via gcloud CLI saat deployment:
# 
# gcloud run deploy shopfloor-dashboard \
#   --set-env-vars CLOUD_SQL_CONNECTION_NAME=PROJECT:REGION:INSTANCE \
#   --set-env-vars DB_USER=postgres \
#   --set-env-vars DB_PASS=your-password \
#   --set-env-vars DB_NAME=shopfloor_db \
#   --set-env-vars FLASK_ENV=production \
#   --set-env-vars SECRET_KEY=your-secret-key \
#   --set-env-vars CORS_ORIGINS=https://yourdomain.com
#
# Atau gunakan Secret Manager untuk credentials yang sensitive
